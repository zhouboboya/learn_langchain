# 将此文件重命名为 .env 并填入你的 API Key
# cp .env.example .env

# DeepSeek API Key（在 https://platform.deepseek.com/api_keys 获取）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# DeepSeek API 地址（OpenAI 兼容协议）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# LangSmith（在 https://smith.langchain.com/ 注册后获取）
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__your-langsmith-key-here
# LANGCHAIN_PROJECT=learn_langchain
